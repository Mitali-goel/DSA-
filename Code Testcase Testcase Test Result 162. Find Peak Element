class Solution {
public:
    int findPeakElement(vector<int>& nums) {

        // if n === 1 
 if (nums.size() == 1){return 0;} // eg[2]
 else if (nums [0] > nums[1]){ return 0;} // eg [5 4 3 2 1]
 else if (nums[nums.size()-1] > nums[nums.size() -2]){return nums.size()-1; }  // eg. [1 2 3 4 5]

        int low = 1 ; int high = nums.size()-2;
        int mid ; 
         while(low<= high){
            mid = (low + high )/2;
            if(nums[mid -1] < nums[mid] && nums[mid] > nums[mid+1]){
                return mid ; 
            }

// we can also use && operation but this can result false statement when we find peak for array having multiple value 
// [ 1 5 1 2 1] thats why using ||
            else if (nums[mid-1] < nums[mid]|| nums[mid] < nums[mid+1]){
                low = mid+1;
            }else if (nums[mid-1] > nums[mid]|| nums[mid] > nums[mid+1]){
                high = mid -1;
            }
            
         }
      return -1;
    }
};
