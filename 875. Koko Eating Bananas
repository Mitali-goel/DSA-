class Solution {
public:
 int minEatingSpeed(vector<int>& piles, int h) {
 int low = 1 ; int high = *max_element(piles.begin() , piles.end());
int mid ; int ans = high ;
while (low <= high){
    mid = (low + high)/2;
    long long time = 0 ;
    for (int i = 0 ; i < piles.size() ; i++){
        // celling function
        if(piles[i] % mid != 0){ 
            time = time + piles[i]/mid +1;
        }else if (piles[i] % mid == 0){ 
            time = time + (piles[i]/mid) ;
        }  
}
    
    if (time <= h){
        ans = mid ;
        high = mid -1;
    }else {
        low = mid +1 ;
    }
}
return ans ;
        
    }
};
