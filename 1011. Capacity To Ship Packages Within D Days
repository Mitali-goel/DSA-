class Solution {
public:
    int shipWithinDays(vector<int>& weights, int days) {
            // minimum we have to pick max value of weights 
        int low = *max_element (weights.begin() , weights.end());
            // high is equal to sum of all weights
        int sum = 0;
        for (int i = 0 ; i < weights.size() ; i++){
            sum += weights[i];
        }
        int high = sum ; 
        int mid ; int ans = high ; 
        while (low <= high){
            mid = (low + high) / 2 ;

            int nod = 1 ; int count = 0 ; 
            for(int i = 0 ; i < weights.size() ; i++){

                if(weights[i] + count <= mid ){
                    count += weights[i];
                }else {
                    // weight added to next day count 
                    count = weights[i];
                    nod ++;
                }
            }
            if (nod <= days){
                ans = mid ; 
                high = mid -1;
            }else {
                low =mid +1;
            }
        }
        return ans ;
    }
};
