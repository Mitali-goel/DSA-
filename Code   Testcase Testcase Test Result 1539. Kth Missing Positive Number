class Solution {
public:
    int findKthPositive(vector<int>& arr, int k) {
       //     int j = 1 ; int i = 0 ; int count = 0;
    //   while (i < arr.size()){
    //     if (count == k ){
    //         return j-1 ;
    //     }
    //     if(arr[i] == j ){
    //         i++;
    //         j++;
    //     }else{
    //         count ++;
    //         j++;
    //     }
        
    //   }

    int low = 0 ; int high =arr.size() -1;
    int mid ; int missing ;
    while (low <= high){
        mid = (low + high)/2;

        missing = arr[mid] -(mid +1);

        if (missing < k ){
            low = mid + 1 ;
        }else {
            high = mid -1;
        }
    }
    // formula derived
    //let eg [4,6 , 7, 10] k = 3
    // l = 0 , h = 3 , m = 1 , arr[m] = 6
    //missing = 4 > k 
    // l = 0 ; h = 0 , m = 0 ; arr[m] = 4
    // missing = 3 == k  ; high = m -1 == -1 
    // thats why cant return ans in high format 
     // in another cassses

    //  eg [3,5,7,10]  k = 6 , l = 0 , h = 3 ; m = 1  arr[m] = 5
    //  missing = 5 - (1+1) = 3 
    //  l = 2 , h = 3 , m = 2 arr[m] = 7 missing = 7-(2+1) = 4 
    //  l = 3 , h = 3 ; m = 3 , arr[m] = 10 missing = 10 - (3+1) = 6
    //  l = 3 , h = 2  (high < low)
    //  ans = arr[high] + k - (missing at high) =>  a = 2-3+3+1 = 3
    //simplifying 
    // arr[high] + k - (arr [high] - high -1) 
    // k + high + 1 as (low = high +1)
    // simplifies to low + k

        return low +k ;  
    }
};
