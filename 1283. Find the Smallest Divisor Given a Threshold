class Solution {
public:
    int smallestDivisor(vector<int>& nums, int threshold) {
        int low = 1 ; int high = *max_element(nums.begin() , nums.end());
        int mid ; int ans = high ;
        while (low <= high){
            mid = (low + high)/2;
            int sum = 0 ;
             for (int i = 0 ; i < nums.size() ; i++){
                // celling fn 
                if(nums[i] % mid != 0){
                    sum += nums[i] / mid +1;
                }else {
                     sum += nums[i] / mid ;
                }
             }
            if (sum <= threshold){
                ans = mid ;
                high = mid -1;
            }else {
                low = mid + 1 ;
            }
        }
        return ans ;
    }
};
